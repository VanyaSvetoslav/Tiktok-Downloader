# Required
BOT_TOKEN=123456:ABC-your-telegram-bot-token

# Optional — improves success rate when TikTok rate-limits requests
TIKTOK_COOKIE=

# Optional — HTTP/SOCKS5 proxy used by yt-dlp and direct downloaders
# Examples:
#   http://user:pass@host:port
#   socks5://user:pass@host:port
PROXY_URL=

# Optional — Tikhub API key. Used only by the Tikhub fallback strategy.
TIKHUB_API_KEY=

# Optional — HTTP port used for the Railway health check
PORT=8080

# Optional — directory used for temporary downloads (default: $TMPDIR)
WORK_DIR=
